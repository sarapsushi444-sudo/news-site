---
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import KeywordFilter from '../components/KeywordFilter.astro';

// Import news data
import newsData from '../data/news.json';

const philippinesIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
</svg>`;

const energyIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
</svg>`;

const techIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
</svg>`;

const worldIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
</svg>`;

const usStocksIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
</svg>`;

const entertainmentIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
</svg>`;
---

<Layout title="Daily News Digest - Philippines, World News, Energy, US Stocks, Tech & Entertainment">
  <!-- Keyword Filter -->
  <KeywordFilter />
  
  <!-- Philippines Section -->
  <section data-section="philippines" class="mb-12">
    <SectionHeader
      title="🇵🇭 Philippines Pulse"
      subtitle="BGC, Makati & Metro Manila trends, local news and updates"
      icon={philippinesIcon}
      color="blue"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {newsData.philippines && newsData.philippines.length > 0 ? (
        newsData.philippines.slice(0, 8).map((article) => (
          <NewsCard
            title={article.title}
            description={article.description}
            source={article.source}
            publishedAt={article.publishedAt}
            url={article.url}
            imageUrl={article.imageUrl}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-slate-500 dark:text-slate-400">No articles available. Check back later!</p>
        </div>
      )}
    </div>
  </section>

  <!-- World Section -->
  <section data-section="world" class="mb-12">
    <SectionHeader
      title="🌍 World News"
      subtitle="Global headlines, international developments and breaking news"
      icon={worldIcon}
      color="indigo"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {newsData.world && newsData.world.length > 0 ? (
        newsData.world.slice(0, 8).map((article) => (
          <NewsCard
            title={article.title}
            description={article.description}
            source={article.source}
            publishedAt={article.publishedAt}
            url={article.url}
            imageUrl={article.imageUrl}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-slate-500 dark:text-slate-400">No articles available. Check back later!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Energy & Markets Section -->
  <section data-section="energy" class="mb-12">
    <SectionHeader
      title="⚡ Energy & Markets"
      subtitle="Oil, gas, energy sector, stock markets and financial developments"
      icon={energyIcon}
      color="orange"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {newsData.energy && newsData.energy.length > 0 ? (
        newsData.energy.slice(0, 8).map((article) => (
          <NewsCard
            title={article.title}
            description={article.description}
            source={article.source}
            publishedAt={article.publishedAt}
            url={article.url}
            imageUrl={article.imageUrl}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-slate-500 dark:text-slate-400">No articles available. Check back later!</p>
        </div>
      )}
    </div>
  </section>

  <!-- US Stock Market Section -->
  <section data-section="usStocks" class="mb-12">
    <SectionHeader
      title="💹 US Stock Market"
      subtitle="MU, SNDK, WDC, STX, AI stocks, tech stocks and market analysis"
      icon={usStocksIcon}
      color="emerald"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {newsData.usStocks && newsData.usStocks.length > 0 ? (
        newsData.usStocks.slice(0, 8).map((article) => (
          <NewsCard
            title={article.title}
            description={article.description}
            source={article.source}
            publishedAt={article.publishedAt}
            url={article.url}
            imageUrl={article.imageUrl}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-slate-500 dark:text-slate-400">No articles available. Check back later!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Tech Section -->
  <section data-section="tech" class="mb-12">
    <SectionHeader
      title="📈 Tech & Innovation"
      subtitle="AI, semiconductors, startups, and technology breakthroughs"
      icon={techIcon}
      color="purple"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {newsData.tech && newsData.tech.length > 0 ? (
        newsData.tech.slice(0, 8).map((article) => (
          <NewsCard
            title={article.title}
            description={article.description}
            source={article.source}
            publishedAt={article.publishedAt}
            url={article.url}
            imageUrl={article.imageUrl}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-slate-500 dark:text-slate-400">No articles available. Check back later!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Entertainment Section -->
  <section data-section="entertainment" class="mb-12">
    <SectionHeader
      title="🎬 Entertainment"
      subtitle="Movies, TV shows, celebrity news and Hollywood updates"
      icon={entertainmentIcon}
      color="pink"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {newsData.entertainment && newsData.entertainment.length > 0 ? (
        newsData.entertainment.slice(0, 8).map((article) => (
          <NewsCard
            title={article.title}
            description={article.description}
            source={article.source}
            publishedAt={article.publishedAt}
            url={article.url}
            imageUrl={article.imageUrl}
          />
        ))
      ) : (
        <div class="col-span-full text-center py-12">
          <p class="text-slate-500 dark:text-slate-400">No articles available. Check back later!</p>
        </div>
      )}
    </div>
  </section>
</Layout>